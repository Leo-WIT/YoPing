<Window x:Class="vmPing.UI.FloodHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:vmPing.UI"
        xmlns:classes="clr-namespace:vmPing.Classes"
        Title="YoPing - 压力测试"
        Height="250"
        Width="400"
        ResizeMode="CanMinimize"
        Background="{DynamicResource Theme.Brush.WindowBackground}">

    <Window.Resources>
        <!-- Value converters -->
        <classes:BoolToStringConverter x:Key="BoolToStringConverter" FalseValue="开始洪泛" TrueValue="停止洪泛"/>
        <classes:BooleanToHiddenVisibilityConverter x:Key="BooleanToHiddenVisibilityConverter" />
        <classes:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <classes:BooleanToImageConverter x:Key="BooleanToImageConverter" />
        

        <!-- Style for hostname textbox -->
        <ControlTemplate x:Key="TextBoxBaseControlTemplatez" TargetType="{x:Type TextBoxBase}">
            <Border Background="{TemplateBinding Background}"
                    x:Name="Bd"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    BorderBrush="{TemplateBinding BorderBrush}">
                <ScrollViewer x:Name="PART_ContentHost" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource Theme.Brush.ContainerDisabled}" />
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextMuted}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Hostname textbox -->
            <TextBox Name="txtHostname"
                     FontSize="18" FontWeight="Bold"
                     Background="{DynamicResource Theme.Brush.Container}"
                     Foreground="{DynamicResource Theme.Brush.Text}"
                     BorderThickness="2,2,0,2"
                     BorderBrush="{DynamicResource Theme.Brush.Border}"
                     VerticalContentAlignment="Center"
                     Template="{StaticResource TextBoxBaseControlTemplatez}"
                     IsEnabled="{Binding IsActive, Converter={StaticResource InverseBooleanConverter}}"
                     />

            <!-- Trace Route button -->
            <Button Name="btnFloodHost"
                    Click="btnFloodHost_Click"
                    Grid.Column="1"
                    IsDefault="True"
                    FontSize="14"
                    Padding="0,6"
                    Width="125"
                    Background="{DynamicResource Theme.Brush.Primary}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="floodHostButton_border" BorderThickness="2" BorderBrush="{DynamicResource Theme.Brush.Border}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{Binding IsActive, Converter={StaticResource BooleanToImageConverter}}"
                                       Margin="0,0,8,0" Width="16" Height="16" />
                                <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStringConverter}}"
                                           Foreground="{DynamicResource Theme.Brush.TextLightSolid}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="floodHostButton_border" Property="Background" Value="{DynamicResource Theme.Brush.PrimaryHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="floodHostButton_border" Property="Background" Value="{DynamicResource Theme.Brush.PrimaryHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>


        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="已发送包数："
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsSent"
                           Text="{Binding Path=PacketsSent, StringFormat='#,0'}"
                           Foreground="{DynamicResource Theme.Brush.StatusAddress}"
                           FontSize="22" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="已接收包数："
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsReceived"
                           Text="{Binding Path=PacketsReceived, StringFormat='#,0'}"
                           Foreground="{DynamicResource Theme.Brush.InfoText}"
                           FontSize="22" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="丢失包数："
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,15,0"
                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Name="tbPacketsLost"
                           Text="{Binding Path=PacketsLost, StringFormat='#,0'}"
                           Foreground="#dc322f"
                           FontSize="22" />
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Text="洪泛进行中..."
                   Name="tbStatus"
                   Margin="0,7" HorizontalAlignment="Center"
                   Foreground="{DynamicResource Theme.Brush.TextMuted}"
                   FontSize="13"
                   Visibility="{Binding IsActive, Converter={StaticResource BooleanToHiddenVisibilityConverter}}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True" >
                                        <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Opacity)"
                                                         From="1" To=".2"
                                                         BeginTime="0:0:1.25"
                                                         Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(TextBlock.Opacity)"
                                                         From="1" To="1" Duration="0:0:0.0" FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        
        <Label Grid.Row="1" Grid.RowSpan="2"
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
               Name="lblInformation"
               Foreground="{DynamicResource Theme.Brush.TextMuted}" Background="{DynamicResource Theme.Brush.WindowBackground}"
               Padding="40,0"
               FontSize="14">
            <TextBlock TextWrapping="Wrap" TextAlignment="Justify">
                洪泛主机会持续向目标地址发送 ICMP Ping 数据包，适合用于短时间连通性验证或轻量压力测试。
                请仅在你有权限的网络环境中使用，并在完成测试后及时停止。
            </TextBlock>
        </Label>
        
    </Grid>
</Window>
