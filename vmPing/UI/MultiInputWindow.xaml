<Window x:Class="vmPing.UI.MultiInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="批量地址"
        UseLayoutRounding="True"
        Height="450" MinHeight="250"
        Width="430" MinWidth="420"
        Background="{DynamicResource Theme.Brush.ContainerDisabled}"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_SourceInitialized"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="TextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.Container}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.Border}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Text}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="KeyboardNavigation.TabNavigation" Value="None"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="AllowDrop" Value="true"/>
            <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#FF7EB4EA"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="#FF569DE5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsInactiveSelectionHighlightEnabled" Value="true"/>
                        <Condition Property="IsSelectionActive" Value="false"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="SelectionBrush" Value="{DynamicResource {x:Static SystemColors.InactiveSelectionHighlightBrushKey}}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel LastChildFill="False">
            <Image DockPanel.Dock="Left" Source="{StaticResource icon.input-addresses}" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,8,0"/>
            <TextBlock DockPanel.Dock="Left"
                       Text="批量地址"
                       Style="{StaticResource OptionHeaderTextStyle}" />
            <Label DockPanel.Dock="Left" Style="{StaticResource LabelToolTip}" MaxWidth="250">
                <TextBlock>
                    支持逗号或换行分隔，系统会自动去重并校验地址格式。<LineBreak/>
                    也可以导入 TXT/CSV 文件。
                </TextBlock>
            </Label>
        </DockPanel>

        <!-- Input -->
        <TextBox x:Name="MultiAddress"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 FontFamily="Consolas"
                 FontSize="16"
                 Padding="5"
                 AllowDrop="True"
                 PreviewDragOver="MultiAddress_PreviewDragOver"
                 Drop="MultiAddress_Drop"/>

        <!-- Buttons section -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
                <Button Style="{StaticResource ButtonStandardStyle}"
                        Grid.Column="0"
                        Content="导入"
                        Width="82"
                        Click="Import_Click"/>
                <Button Style="{StaticResource ButtonStandardStyle}"
                        Grid.Column="2"
                        Content="导出"
                        Width="82"
                        Click="Export_Click"/>
                <Button Style="{StaticResource ButtonStandardStyle}"
                        Grid.Column="4"
                        Content="确定"
                        Width="88"
                        Click="OK_Click"/>
                <Button Style="{StaticResource ButtonStandardStyle}"
                        Grid.Column="6"
                        Content="取消"
                        Width="88"
                        IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
