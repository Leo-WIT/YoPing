<Window x:Class="vmPing.UI.NetworkToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="网络工具" Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.Brush.WindowBackground}"
        Foreground="{DynamicResource Theme.Brush.Text}"
        Icon="../vmPing.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Theme.Brush.Primary}" Padding="15,10">
            <TextBlock Text="网络工具" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Theme.Brush.TextLightSolid}"/>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="10" TabStripPlacement="Left"
                    Background="{DynamicResource Theme.Brush.WindowBackground}">
            <!-- CIDR Calculator -->
            <TabItem Header="CIDR 计算">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="CIDR 计算" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource Theme.Brush.Text}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CIDR:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                            <TextBox Grid.Column="1" x:Name="CidrInput" Text="192.168.1.0/24" Padding="5"/>
                            <Button Grid.Column="2" Content="计算" Margin="10,0,0,0" Padding="15,5" Click="CalculateCidr_Click"
                                    Style="{DynamicResource ButtonStyle}"/>
                        </Grid>

                        <TextBlock x:Name="CidrError" Foreground="#FF6B6B" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource Theme.Brush.Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="计算结果" FontWeight="Bold" Margin="0,0,0,5"
                                           Foreground="{DynamicResource Theme.Brush.Text}"/>
                                <ItemsControl x:Name="CidrResults">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontWeight="Bold"
                                                           Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- VLSM Planner -->
            <TabItem Header="VLSM 规划">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="VLSM 规划" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource Theme.Brush.Text}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="主网段:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                            <TextBox Grid.Column="1" x:Name="VlsmBaseInput" Text="192.168.0.0/24" Padding="5"/>
                        </Grid>

                        <TextBlock Text="子网需求:" FontWeight="Bold" Margin="0,0,0,5"
                                   Foreground="{DynamicResource Theme.Brush.Text}"/>
                        <ItemsControl x:Name="VlsmRequirements">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Name}" Padding="3" Margin="0,0,5,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Hosts}" Padding="3" Margin="0,0,5,0"/>
                                        <Button Grid.Column="2" Content="删除" Padding="10,3" Click="RemoveVlsmRequirement_Click"
                                                Tag="{Binding}" Style="{DynamicResource ButtonStyle}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <Button Content="添加子网" Padding="15,5" Margin="0,0,10,0" Click="AddVlsmRequirement_Click" Style="{DynamicResource ButtonStyle}"/>
                            <Button Content="计算" Padding="15,5" Click="CalculateVlsm_Click" Style="{DynamicResource ButtonStyle}"/>
                        </StackPanel>

                        <TextBlock x:Name="VlsmError" Foreground="#FF6B6B" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <ItemsControl x:Name="VlsmResults">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource Theme.Brush.Border}" BorderThickness="1" Padding="10" Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"
                                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CIDR:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Cidr}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="网络地址:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Network}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="子网掩码:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Mask}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="可用主机数:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding UsableHosts}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="首个可用 IP:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FirstHost}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="最后可用 IP:" Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastHost}" Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Subnet Enumeration -->
            <TabItem Header="子网枚举">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="子网枚举" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource Theme.Brush.Text}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="大网段:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                            <TextBox Grid.Column="1" x:Name="EnumBaseInput" Text="192.168.0.0/16" Padding="5"/>
                            <TextBlock Grid.Column="2" Text="目标前缀:" VerticalAlignment="Center" Margin="10,0,10,0"
                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                            <TextBox Grid.Column="3" x:Name="EnumTargetPrefix" Text="24" Padding="5"/>
                        </Grid>

                        <Button Content="枚举" Padding="15,5" Margin="0,0,0,10" HorizontalAlignment="Left" Click="EnumerateSubnets_Click" Style="{DynamicResource ButtonStyle}"/>

                        <TextBlock x:Name="EnumError" Foreground="#FF6B6B" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <DataGrid x:Name="EnumResults" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="All">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                <DataGridTextColumn Header="CIDR" Binding="{Binding Cidr}" Width="150"/>
                                <DataGridTextColumn Header="网络地址" Binding="{Binding Network}" Width="120"/>
                                <DataGridTextColumn Header="广播地址" Binding="{Binding Broadcast}" Width="120"/>
                                <DataGridTextColumn Header="子网掩码" Binding="{Binding Mask}" Width="120"/>
                                <DataGridTextColumn Header="可用主机" Binding="{Binding UsableHosts}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- IP Converter -->
            <TabItem Header="IP 转换">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="IP 转换" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource Theme.Brush.Text}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="输入:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource Theme.Brush.Text}"/>
                            <TextBox Grid.Column="1" x:Name="ConvertInput" Text="192.168.1.1" Padding="5"/>
                            <Button Grid.Column="2" Content="转换" Margin="10,0,0,0" Padding="15,5" Click="ConvertIp_Click" Style="{DynamicResource ButtonStyle}"/>
                        </Grid>

                        <TextBlock x:Name="ConvertError" Foreground="#FF6B6B" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource Theme.Brush.Border}" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <TextBlock Text="转换结果" FontWeight="Bold" Margin="0,0,0,5"
                                           Foreground="{DynamicResource Theme.Brush.Text}"/>
                                <ItemsControl x:Name="ConvertResults">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Label}" FontWeight="Bold"
                                                           Foreground="{DynamicResource Theme.Brush.TextMuted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource Theme.Brush.Text}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
