<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:SystemColors="clr-namespace:System.Windows;assembly=PresentationFramework">
    <!-- Bootstrap 风格浅色主题令牌，对应 antd theme.defaultAlgorithm + Bootstrap 视觉增强 -->
    <Color x:Key="Theme.Color.Primary">#337AB7</Color>
    <Color x:Key="Theme.Color.PrimaryHover">#286090</Color>
    <Color x:Key="Theme.Color.Info">#3A87AD</Color>
    <Color x:Key="Theme.Color.InfoText">#31708F</Color>
    <Color x:Key="Theme.Color.Text">#333333</Color>
    <Color x:Key="Theme.Color.TextMuted">#6B7280</Color>
    <Color x:Key="Theme.Color.TextLightSolid">#FFFFFF</Color>
    <Color x:Key="Theme.Color.Border">#999999</Color>
    <Color x:Key="Theme.Color.Split">#DDDDDD</Color>
    <Color x:Key="Theme.Color.Container">#FFFFFF</Color>
    <Color x:Key="Theme.Color.ContainerDisabled">#F5F5F5</Color>
    <Color x:Key="Theme.Color.WindowBackground">#FFFFFF</Color>
    <Color x:Key="Theme.Color.AppBackground">#D5D5D5</Color>
    <Color x:Key="Theme.Color.MenuBackground">#FFFFFF</Color>
    <Color x:Key="Theme.Color.Placeholder">#9CA3AF</Color>

    <SolidColorBrush x:Key="Theme.Brush.Primary" Color="{StaticResource Theme.Color.Primary}"/>
    <SolidColorBrush x:Key="Theme.Brush.PrimaryHover" Color="{StaticResource Theme.Color.PrimaryHover}"/>
    <SolidColorBrush x:Key="Theme.Brush.Info" Color="{StaticResource Theme.Color.Info}"/>
    <SolidColorBrush x:Key="Theme.Brush.InfoText" Color="{StaticResource Theme.Color.InfoText}"/>
    <SolidColorBrush x:Key="Theme.Brush.Text" Color="{StaticResource Theme.Color.Text}"/>
    <SolidColorBrush x:Key="Theme.Brush.TextMuted" Color="{StaticResource Theme.Color.TextMuted}"/>
    <SolidColorBrush x:Key="Theme.Brush.TextLightSolid" Color="{StaticResource Theme.Color.TextLightSolid}"/>
    <SolidColorBrush x:Key="Theme.Brush.Border" Color="{StaticResource Theme.Color.Border}"/>
    <SolidColorBrush x:Key="Theme.Brush.Split" Color="{StaticResource Theme.Color.Split}"/>
    <SolidColorBrush x:Key="Theme.Brush.Container" Color="{StaticResource Theme.Color.Container}"/>
    <SolidColorBrush x:Key="Theme.Brush.ContainerDisabled" Color="{StaticResource Theme.Color.ContainerDisabled}"/>
    <SolidColorBrush x:Key="Theme.Brush.WindowBackground" Color="{StaticResource Theme.Color.WindowBackground}"/>
    <SolidColorBrush x:Key="Theme.Brush.AppBackground" Color="{StaticResource Theme.Color.AppBackground}"/>
    <SolidColorBrush x:Key="Theme.Brush.MenuBackground" Color="{StaticResource Theme.Color.MenuBackground}"/>
    <SolidColorBrush x:Key="Theme.Brush.Placeholder" Color="{StaticResource Theme.Color.Placeholder}"/>
    <SolidColorBrush x:Key="Theme.Brush.DataGridHeaderBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Theme.Brush.DataGridHeaderForeground" Color="#333333"/>
    <SolidColorBrush x:Key="Theme.Brush.DataGridRowBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.Brush.DataGridRowHover" Color="#EAF2F8"/>
    <SolidColorBrush x:Key="Theme.Brush.DataGridGridLine" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="Theme.Brush.StatusAddress" Color="#2E7D32"/>
    <SolidColorBrush x:Key="Theme.Brush.StatusAlias" Color="#333333"/>
    <SolidColorBrush x:Key="Theme.Brush.StatusDate" Color="#6B7280"/>
    <SolidColorBrush x:Key="Theme.Brush.StatusTime" Color="#333333"/>
    <SolidColorBrush x:Key="Theme.Brush.StatusEmptyTitle" Color="#3A87AD"/>
    <SolidColorBrush x:Key="Theme.Brush.WindowTitleBar" Color="#F5F5F5"/>

    <SolidColorBrush x:Key="{x:Static SystemColors:SystemColors.WindowBrushKey}" Color="{StaticResource Theme.Color.WindowBackground}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors:SystemColors.ControlBrushKey}" Color="{StaticResource Theme.Color.ContainerDisabled}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors:SystemColors.ControlTextBrushKey}" Color="{StaticResource Theme.Color.Text}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors:SystemColors.WindowTextBrushKey}" Color="{StaticResource Theme.Color.Text}"/>

    <LinearGradientBrush x:Key="Theme.Brush.ButtonPrimary" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#337AB7" Offset="0"/>
        <GradientStop Color="#286090" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Theme.Brush.ButtonPrimaryHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#286090" Offset="0"/>
        <GradientStop Color="#204D74" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Theme.Brush.ButtonDefault" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#E6E6E6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Theme.Brush.ButtonDefaultHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E6E6E6" Offset="0"/>
        <GradientStop Color="#D4D4D4" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Theme.Brush.DropdownItemHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#286090" Offset="0"/>
        <GradientStop Color="#337AB7" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Theme.Brush.ProgressTrack" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5BC0DE" Offset="0"/>
        <GradientStop Color="#3A87AD" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
